  hs-source-dirs:
      src
      legacy
      app
  exposed-modules:
      Application
      CategoryRule
      FAMES
      FAX
      Foundation
      Handler.Administrator
      Handler.Bank
      Handler.Common
      Handler.CsvUtils
      Handler.Customers
      Handler.Customers.DPD
      Handler.Customers.Invoices
      Handler.Customers.Lookup
      Handler.Customers.Map
      Handler.Customers.ShippingDetails
      Handler.Dashboard
      Handler.FA
      Handler.FA.Def
      Handler.FAMES
      Handler.FAMES.Def
      Handler.FAX
      Handler.FAX.Def
      Handler.GL
      Handler.GL.Check
      Handler.GL.Check.ItemCost
      Handler.GL.Check.ItemCost.Common
      Handler.GL.CheckAIS
      Handler.GL.GLEnterReceiptSheet
      Handler.GL.GLEnterReceiptSheet.ReceiptRow
      Handler.GL.Payroll
      Handler.GL.Payroll.Calendar
      Handler.GL.Payroll.Common
      Handler.GL.Payroll.Import
      Handler.GL.Payroll.Payroo
      Handler.GL.Payroll.QuickAdd
      Handler.GL.Payroll.Summary
      Handler.GL.TaxReport
      Handler.GL.TaxReport.Common
      Handler.GL.TaxReport.HMRC
      Handler.GL.TaxReport.Processor
      Handler.GL.TaxReport.Types
      Handler.GL.Tools
      Handler.Home
      Handler.Items
      Handler.Items.Batches
      Handler.Items.Batches.Matches
      Handler.Items.Category
      Handler.Items.Category.Cache
      Handler.Items.Common
      Handler.Items.History
      Handler.Items.Index
      Handler.Items.Report
      Handler.Items.Reports.Common
      Handler.Items.Reports.Forecast
      Handler.Items.Reports.NewForecast
      Handler.Planner
      Handler.Planner.Exec
      Handler.Planner.FamesImport
      Handler.Planner.View
      Handler.Table
      Handler.Util
      Handler.VAT
      Handler.WH
      Handler.WH.Barcode
      Handler.WH.Boxtake
      Handler.WH.Boxtake.Adjustment
      Handler.WH.Boxtake.Common
      Handler.WH.Boxtake.Upload
      Handler.WH.Dimensions
      Handler.WH.Location
      Handler.WH.PackingList
      Handler.WH.PLToPlanner
      Handler.WH.StockAdjustment
      Handler.WH.Stocktake
      Import
      Import.NoFoundation
      Locker
      Model
      Model.Boxtake
      Model.DocumentKey
      ModelField
      Role
      RoutePiece
      Settings
      Settings.StaticFiles
      Util.Cache
      Util.Decimal
      Util.EnumTree
      Util.ForConduit
      Util.SameCons
      Util.Transformable
      Util.ValidField
      BankReconciliate
      Curl
      Customers.Settings
      FATransType
      GL
      GL.Check.ItemCostSettings
      GL.FA
      GL.Payroll.Nest
      GL.Payroll.Parser
      GL.Payroll.Report
      GL.Payroll.Settings
      GL.Payroll.Timesheet
      GL.Receipt
      GL.TaxReport
      GL.TaxReport.Settings
      GL.TaxReport.Types
      GL.Utils
      Items
      Items.Internal
      Items.SharedStockAdjustment
      Items.Types
      WH.Barcode
      WH.FA
      WH.FA.Curl
      WH.FA.Types
      WH.PackingList.Internal

common tools
  hs-source-dirs:
      tools
  if flag(tools)
     buildable: True
  else
    buildable: False
executable DPDDump
  import: deps, build, tools
  main-is: DPDDump.hs
  other-modules:
      DPDLib

executable DPDImport
  import: deps, build, tools
  main-is: DPDImport.hs
  other-modules:
      DPDLib

executable FAGenerator
  import: deps, build, tools
  main-is: FAGenerator.hs

executable FPlanner
  import: build, deps
  main-is: Planner.hs
  if flag(brick)
     buildable: True
  else 
    buildable: False
  build-depends: Fames
  hs-source-dirs:
      tools
  ghc-options: -threaded -rtsopts

executable Fames
  import: deps, build
  main-is: main.hs
  build-depends: Fames
  other-modules:
      Curl
      Customers.Settings
      FATransType
      GL
      GL.Check.ItemCostSettings
      GL.FA
      GL.Payroll.Nest
      GL.Payroll.Parser
      GL.Payroll.Report
      GL.Payroll.Settings
      GL.Payroll.Timesheet
      GL.Receipt
      GL.TaxReport
      GL.TaxReport.Settings
      GL.TaxReport.Types
      GL.Utils
      Items
      Items.Internal
      Items.SharedStockAdjustment
      Items.Types
      WH.Barcode
      WH.FA
      WH.FA.Curl
      WH.FA.Types
      WH.PackingList.Internal
      Paths_Fames
  hs-source-dirs:
      app
  ghc-options: -threaded -rtsopts -with-rtsopts=-N -j6

test-suite test
  import: deps, build
  type: exitcode-stdio-1.0
  main-is: Spec.hs
  other-modules:
      GL.Payroll.ParserSpec
      GL.Payroll.TimesheetSpec
      GL.Payroll.UtilsSpec
      GL.ReceiptProcessingSpec
      Handler.AuthSpec
      Handler.CommonSpec
      Handler.FaSpec
      Handler.GLEnterReceiptSheetSpec
      Handler.Items.BatchSpec
      Handler.WHBarcodeSpec
      Handler.WHBoxtake.AdjustementSpec
      Handler.WHBoxtake.UploadSpec
      Handler.WHPackingListSpec
      Handler.WHStockAdjustmentSpec
      Handler.WHStocktakeSpec
      Items.CategorySpec
      Items.InternalSpec
      Legacy.BankReconciliateSpec
      RoleSpec
      TestImport
      Util.CacheSpec
      Util.DecimalSpec
      WH.BarcodeSpec
      WH.PackingList.InternalSpec
      Paths_Fames
  ghc-options: -w -threaded -rtsopts -with-rtsopts=-N

benchmark bench
  import: deps, build
  type: exitcode-stdio-1.0
  main-is: bench.hs
  other-modules:
      BenchImport
      Paths_Fames
  hs-source-dirs:
      benchmarks
  ghc-options: -rtsopts -Wno-missing-exported-signatures
